#pragma once

// Device credentials, read only through config.c (ADR-0004). Copy this file to
// secrets.h (which is gitignored) and fill in your own values before flashing.
// A later ADR is expected to replace this with runtime provisioning.

#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// Bot token from @BotFather.
#define TELEGRAM_BOT_TOKEN "123456789:PASTE_BOT_TOKEN_HERE"

// Chat IDs allowed to wake the host (ADR-0002). Brace-enclosed, comma-separated
// int64 literals, e.g. { 123456789LL, -1009876543210LL }. Find yours by
// messaging the bot and reading the message's "chat":{"id":...} field, or via
// @userinfobot.
#define TELEGRAM_ALLOWED_CHAT_IDS { 0LL }
